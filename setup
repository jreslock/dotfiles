#!/usr/bin/env bash

# Sets up the shell environment on a Linux (Ubuntu/Debian) host.
#
# Symlinking the dotfiles is the only step that must succeed, so it runs first
# and unconditionally. Tool installs are best-effort: each only runs if the
# tool is missing and a failure logs a warning instead of aborting. On a
# pre-provisioned host (e.g. an OM1 devenv instance) every tool is already
# present, so the install section is skipped entirely and setup just symlinks.

# Keep unset-variable and pipe-failure safety. Deliberately NOT `-e`: a failed
# best-effort install must not abort the run before/after the symlinks.
set -uo pipefail

log() { echo "[$(date -Iseconds)] $*"; }
warn() { log "WARN: $*"; }

# Resolve the repo root from this script's own location so setup can be run
# from anywhere (including as a dotfiles provisioning hook).
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
log "Using dotfiles repo at: $REPO_DIR"

# Architecture, used by the AWS CLI and ECR helper download URLs.
detect_arch() {
    ARCH=$(uname -m)
    if [ "$ARCH" = "x86_64" ] || [ "$ARCH" = "amd64" ]; then
        AWS_ARCH="x86_64"
        target="64bit"
        ecr_arch="amd64"
    elif [ "$ARCH" = "arm64" ] || [ "$ARCH" = "aarch64" ]; then
        AWS_ARCH="aarch64"
        target="arm64"
        ecr_arch="arm64"
    else
        warn "Unsupported architecture: ${ARCH}"
        return 1
    fi
}

# ============================================================================
# Symlink dotfiles (the critical block — runs first, never blocks on installs)
# ============================================================================
log "Installing/symlinking dotfiles..."

# Back up existing real files (skip symlinks from previous runs).
for f in .zshrc .zsh_plugins.txt .p10k.zsh .tmux.conf; do
    if [ -f "$HOME/$f" ] && [ ! -L "$HOME/$f" ]; then
        mv "$HOME/$f" "$HOME/${f}.backup"
        log "Backed up existing $f"
    fi
done

ln -sfn "$REPO_DIR/zsh/.zshrc" "$HOME/.zshrc"
ln -sfn "$REPO_DIR/zsh/.zsh_plugins.txt" "$HOME/.zsh_plugins.txt"
ln -sfn "$REPO_DIR/zsh/.p10k.zsh" "$HOME/.p10k.zsh"
ln -sfn "$REPO_DIR/tmux/.tmux.conf" "$HOME/.tmux.conf"

# gitconfig (skip in devcontainers — they auto-load the host gitconfig).
if [ -z "${REMOTE_CONTAINERS:-}" ] && [ -z "${CODESPACES:-}" ] && [ ! -f "/.dockerenv" ]; then
    if [ -f "$HOME/.gitconfig" ] && [ ! -L "$HOME/.gitconfig" ]; then
        mv "$HOME/.gitconfig" "$HOME/.gitconfig.backup"
        log "Backed up existing .gitconfig"
    fi
    ln -sfn "$REPO_DIR/git/gitconfig_template" "$HOME/.gitconfig"
    log "Installed/symlinked ~/.gitconfig"

    # User-specific identity lives in ~/.gitconfig.local (overrides the template).
    if [ ! -f "$HOME/.gitconfig.local" ]; then
        GIT_USER_NAME="${USER:-$(whoami)}"
        GIT_USER_EMAIL="${GIT_USER_NAME}@users.noreply.github.com"
        log "Setting up git identity as '${GIT_USER_NAME}' <${GIT_USER_EMAIL}>..."
        cat > "$HOME/.gitconfig.local" <<EOF
[user]
    name     = $GIT_USER_NAME
    email    = $GIT_USER_EMAIL
EOF
        log "Created ~/.gitconfig.local"
    else
        log "~/.gitconfig.local already exists, skipping identity setup"
    fi
else
    log "Devcontainer detected, skipping gitconfig (auto-loaded from host)"
fi

# Docker config (enables the ECR credential helper).
mkdir -p "$HOME/.docker"
if [ -f "$HOME/.docker/config.json" ] && [ ! -L "$HOME/.docker/config.json" ]; then
    mv "$HOME/.docker/config.json" "$HOME/.docker/config.json.backup"
    log "Backed up existing docker config.json"
fi
ln -sfn "$REPO_DIR/docker/config.json" "$HOME/.docker/config.json"
log "Installed/symlinked ~/.docker/config.json"

# ============================================================================
# Ensure antidote (plugin manager). .zshrc runs `antidote load` on first launch.
# ============================================================================
if [ ! -d "${HOME}/.antidote" ]; then
    log "Installing antidote..."
    git clone --depth=1 https://github.com/mattmc3/antidote.git "${HOME}/.antidote" \
        || warn "antidote clone failed; first shell launch will retry the load"
else
    log "antidote already installed, updating..."
    (cd "${HOME}/.antidote" && git pull --quiet) || warn "antidote update failed (continuing)"
fi

# ============================================================================
# Best-effort tool installs — only when missing. Skipped on pre-provisioned
# hosts. A failure here warns and continues; the symlinks above already landed.
# ============================================================================

# uv (Astral)
if ! command -v uv &> /dev/null; then
    log "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh || warn "uv install failed"
else
    log "uv already installed"
fi

# apt packages (batched to avoid multiple `apt update` runs).
apt_packages=()
for pkg in zsh less unzip; do
    command -v "$pkg" &> /dev/null || apt_packages+=("$pkg")
done
if [ ${#apt_packages[@]} -gt 0 ]; then
    log "Installing apt packages: ${apt_packages[*]}"
    if sudo -n true 2>/dev/null || sudo true 2>/dev/null; then
        sudo apt update -yqq && sudo apt install -yqq "${apt_packages[@]}" \
            || warn "apt install failed for: ${apt_packages[*]}"
    else
        warn "no sudo available; skipping apt packages: ${apt_packages[*]}"
    fi
fi

# AWS CLI v2
if command -v aws &> /dev/null || [ -x /usr/local/bin/aws ] || [ -x "$HOME/.local/bin/aws" ]; then
    log "AWS CLI v2 already installed"
elif detect_arch; then
    log "Installing AWS CLI v2..."
    TMP_DIR="$(mktemp -d)"
    (
        cd "$TMP_DIR"
        curl -fsSLo awscliv2.zip "https://awscli.amazonaws.com/awscli-exe-linux-${AWS_ARCH}.zip" \
            && unzip -q awscliv2.zip \
            && ./aws/install --install-dir "$HOME/.local/aws-cli" --bin-dir "$HOME/.local/bin" --update
    ) || warn "AWS CLI install failed"
    rm -rf "$TMP_DIR"
fi

# AWS Session Manager Plugin
if ! command -v session-manager-plugin >/dev/null 2>&1; then
    if detect_arch; then
        log "Installing AWS Session Manager Plugin..."
        SSM_URL="https://s3.amazonaws.com/session-manager-downloads/plugin/latest/ubuntu_${target}/session-manager-plugin.deb"
        if curl -fsSLo /tmp/session-manager-plugin.deb "$SSM_URL" \
            && { sudo -n true 2>/dev/null || sudo true 2>/dev/null; }; then
            sudo dpkg -i /tmp/session-manager-plugin.deb || warn "SSM plugin dpkg install failed"
        else
            warn "could not download SSM plugin or no sudo; skipping"
        fi
        rm -f /tmp/session-manager-plugin.deb
    fi
else
    log "AWS Session Manager Plugin already installed"
fi

# Docker ECR Credential Helper
if ! command -v docker-credential-ecr-login &> /dev/null; then
    if detect_arch; then
        log "Installing Docker ECR Credential Helper..."
        ECR_CRED_HELPER_VERSION="0.11.0"
        ECR_URL="https://amazon-ecr-credential-helper-releases.s3.us-east-2.amazonaws.com/${ECR_CRED_HELPER_VERSION}/linux-${ecr_arch}/docker-credential-ecr-login"
        if curl -fSL "$ECR_URL" -o /tmp/docker-credential-ecr-login \
            && { sudo -n true 2>/dev/null || sudo true 2>/dev/null; }; then
            chmod +x /tmp/docker-credential-ecr-login
            sudo mv /tmp/docker-credential-ecr-login /usr/local/bin/docker-credential-ecr-login \
                && log "Docker ECR Credential Helper installed" \
                || warn "ECR helper install failed"
        else
            warn "could not download ECR helper or no sudo; skipping"
        fi
        rm -f /tmp/docker-credential-ecr-login
    fi
else
    log "Docker ECR Credential Helper already installed"
fi

log "Dotfiles installation completed."
log "Restart your shell or run 'exec zsh' to apply changes."
