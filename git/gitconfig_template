[core]
	editor   = vim
	pager    = less -F

[color]
    ui       = auto

[push]
    default  = current
    autoSetupRemote = true

[init]
    defaultBranch = main

[rerere]
    enabled  = true

[pull]
    rebase   = true

[alias]
    ignore	 = "!gi() { curl -L -s https://www.gitignore.io/api/$@ ;}; gi"

[fetch]
    prune	 = true

[diff]
	tool     = vimdiff

[merge]
    tool	 = vimdiff
    conflictStyle = zdiff3

[commit]
    verbose  = true

[user]
	name = Jason Reslock
	email = jreslock@users.noreply.github.com

# Machine-specific overrides (must be last to take precedence)
[include]
    path     = ~/.gitconfig.local
